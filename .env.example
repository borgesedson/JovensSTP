# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# GetStream Configuration
VITE_STREAM_API_KEY=your_stream_api_key_here

# GetStream Video Configuration
VITE_STREAM_VIDEO_API_KEY=your_stream_video_api_key_here
VITE_STREAM_VIDEO_APP_ID=your_stream_video_app_id_here

# Video Calling Features
VITE_ENABLE_VIDEO_CALLS=true
VITE_ENABLE_AUDIO_CALLS=true
VITE_DEFAULT_VIDEO_QUALITY=720p
VITE_MAX_VIDEO_QUALITY=1080p
VITE_ENABLE_CALL_RECORDING=false
VITE_MAX_CALL_DURATION=3600
VITE_ENABLE_NOISE_CANCELLATION=true
