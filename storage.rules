rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permitir leitura de todos os arquivos
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Permitir upload de avatars e stories para usuários autenticados
    match /avatars/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    // Permitir upload de qualquer arquivo para usuários autenticados
    match /{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
